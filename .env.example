# Database Configuration
# Para desenvolvimento local ou produção
DATABASE_URL=postgresql://usuario:senha@host:porta/nome_banco?sslmode=require

# Ou use variáveis separadas (Railway fornece automaticamente)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=portal_pili
# DB_USER=seu_usuario
# DB_PASSWORD=sua_senha

# JWT Secret (para autenticação)
JWT_SECRET=seu-secret-key-aqui-mude-em-producao

# Next.js Environment
NODE_ENV=development

# API URL (para produção)
# NEXT_PUBLIC_API_URL=https://seu-dominio.com

# Email SMTP (para envio de pre-propostas)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha-de-app
# EMAIL_FROM=Portal Pili <noreply@pili.ind.br>
# EMAIL_COMERCIAL=comercial1@pili.ind.br
